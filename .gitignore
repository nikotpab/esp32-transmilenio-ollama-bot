# ============================================================================
# .GITIGNORE - BOT TELEGRAM TRANSMILENIO/SITP
# ============================================================================

# ----------------------------------------------------------------------------
# SECRETOS Y CREDENCIALES (NUNCA SUBIR)
# ----------------------------------------------------------------------------
**/secrets.h
**/.env
**/.env.local
**/.env.production

# ----------------------------------------------------------------------------
# PYTHON
# ----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Entorno virtual
venv/
env/
.venv/

# Distribución / packaging
dist/
build/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp
*.swo

# ----------------------------------------------------------------------------
# PLATFORMIO / ARDUINO
# ----------------------------------------------------------------------------
.pio/
.pioenvs/
libdeps/
.ipioenvs/

# Build artifacts
.build/
*.elf
*.bin
*.hex

# Logs
*.log
logs/

# ----------------------------------------------------------------------------
# SYSTEM
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.temp

# ----------------------------------------------------------------------------
# DOCUMENTACIÓN GENERADA
# ----------------------------------------------------------------------------
*.pdf
*.html
_site/
docs/_build/
